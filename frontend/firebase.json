{
  "hosting": {
    "site": "jamesbarber",
    "public": "dist/james-barber-ui/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}